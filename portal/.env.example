# Copy to .env — never commit .env to git

# Neon Postgres connection string
DATABASE_URL=postgresql://user:pass@ep-something.region.aws.neon.tech/dbname?sslmode=require

# Skip Google auth for local dev — remove or set to false before deploying
SKIP_AUTH=true

# NextAuth — generate secret with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth
# Create at: https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated emails allowed into the Brewery
BREWERY_ALLOWED_EMAILS=jackfperryjr@gmail.com
